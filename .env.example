# Copy this file to .env and fill in your API keys.
# .env is gitignored and will never be committed.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Optional: OpenRouter (alternative access to models)
# OPENROUTER_API_KEY=sk-or-...

# Optional: Hugging Face (for uploading scored outputs)
# HF_TOKEN=hf_...
